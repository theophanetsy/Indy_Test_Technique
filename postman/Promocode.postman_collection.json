    "name": "Promocode API",
    "description": "Collection pour tester l'API de gestion de promocodes.\n\nBase URL: http://localhost:3000\n\nRoutes:\n- POST /api/promocode       → Créer un promocode\n- POST /api/promocode/apply → Valider un promocode",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST /api/promocode — Création",
      "item": [
        {
          "name": "201 — Promocode simple (restriction d'âge)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/promocode", "host": ["{{baseUrl}}"], "path": ["api", "promocode"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SUMMER_AGE\",\n  \"advantage\": { \"percent\": 15 },\n  \"restrictions\": [\n    { \"age\": { \"gt\": 18 } }\n  ]\n}"
            }
          }
        },
        {
          "name": "201 — Promocode avec restriction de date",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
